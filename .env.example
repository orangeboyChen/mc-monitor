# =============================================================================
# mc-monitor — environment variables
#
# Copy this file to `.env.local` for local development, or pass these
# variables to the container at runtime via `docker run -e ...` /
# `docker-compose` / k8s `env`.
# =============================================================================

# ---- Static Minecraft info (REQUIRED) ---------------------------------------
# Path to a JSON file describing the server version, Forge build and Mod pack.
# Mount your config file into the container at this path.
# Default: /config/mc-info.json
# See `mc-info.example.json` for the expected shape.
# MC_INFO_FILE=/config/mc-info.json

# ---- Realtime metrics sources -----------------------------------------------
# `heathcliff26/minecraft-exporter` /metrics endpoint (player presence, TPS,
# memory, etc). Required for the "Server status" and "Server metrics" cards.
# MC_EXPORTER_URL=http://minecraft-exporter:9150/metrics

# Custom mod /metrics endpoint exposed by `mc-server-enhanced-mod`'s
# PrometheusMetricsServer. Required for the "Mod metrics" card and the
# logistics-network storage panel.
# MOD_METRICS_URL=http://minecraft:25585/metrics

# ---- Historical trends (OPTIONAL) -------------------------------------------
# Base URL of a Prometheus instance that scrapes the two endpoints above.
# When unset, the "Historical trends" panel renders a "not configured" message.
# PROM_URL=http://prometheus:9090
